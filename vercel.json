{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/quiz/:slug",
      "destination": "/api/seo-prerender?type=quiz&slug=:slug",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(googlebot|bingbot|yandexbot|duckduckbot|baiduspider|facebookexternalhit|twitterbot|linkedinbot|telegrambot|whatsapp|slackbot|discordbot|pinterestbot|gptbot|chatgpt-user|claude-web|perplexitybot|amazonbot|applebot|semrushbot|ahrefsbot|mj12bot|rogerbot|embedly|showyoubot|outbrain|quora).*"
        }
      ]
    },
    {
      "source": "/article/:slug",
      "destination": "/api/seo-prerender?type=article&slug=:slug",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(googlebot|bingbot|yandexbot|duckduckbot|baiduspider|facebookexternalhit|twitterbot|linkedinbot|telegrambot|whatsapp|slackbot|discordbot|pinterestbot|gptbot|chatgpt-user|claude-web|perplexitybot|amazonbot|applebot|semrushbot|ahrefsbot|mj12bot|rogerbot|embedly|showyoubot|outbrain|quora).*"
        }
      ]
    },
    {
      "source": "/author/:slug",
      "destination": "/api/seo-prerender?type=author&slug=:slug",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(googlebot|bingbot|yandexbot|duckduckbot|baiduspider|facebookexternalhit|twitterbot|linkedinbot|telegrambot|whatsapp|slackbot|discordbot|pinterestbot|gptbot|chatgpt-user|claude-web|perplexitybot|amazonbot|applebot|semrushbot|ahrefsbot|mj12bot|rogerbot|embedly|showyoubot|outbrain|quora).*"
        }
      ]
    },
    {
      "source": "/topic/:slug",
      "destination": "/api/seo-prerender?type=topic&slug=:slug",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(googlebot|bingbot|yandexbot|duckduckbot|baiduspider|facebookexternalhit|twitterbot|linkedinbot|telegrambot|whatsapp|slackbot|discordbot|pinterestbot|gptbot|chatgpt-user|claude-web|perplexitybot|amazonbot|applebot|semrushbot|ahrefsbot|mj12bot|rogerbot|embedly|showyoubot|outbrain|quora).*"
        }
      ]
    },
    { "source": "/post/:id", "destination": "/api/redirect-post?id=:id" },
    { "source": "/(.*)", "destination": "/" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/sitemap-news.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=1800" }
      ]
    },
    {
      "source": "/feed.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/rss+xml; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=1800" }
      ]
    },
    {
      "source": "/:path*.(jpg|png|webp|svg)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ]
}
